MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 522684982}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 0ff7f7e0eae93094d9e58de2b894608b, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::SCR_ControladorDialogo
  personajeIzquierda: {fileID: 1780509490}
  personajeDerecha: {fileID: 668789197}
  etiquetaNombreIzquierda: {fileID: 1079692653}
  textoNombreIzquierda: {fileID: 1543245362}
  etiquetaNombreDerecha: {fileID: 1318666299}
  textoNombreDerecha: {fileID: 1270095366}
  textoCuerpo: {fileID: 1159875510}
  velocidadEscribir: 0.05
  colorDesenfoque: {r: 0.3, g: 0.3, b: 0.3, a: 1}
  idDeEsteNivel: SCN_Dialogo3
  dialogoCompleto:
  - quienHabla: 0
    nombre: MAO MAO
    texto: "Aqu\xED tienes Natsu. Espero que lo\r\ndisfrutes mucho.\r\n"
  - quienHabla: 1
    nombre: NATSU
    texto: "T\xEDa Mao Mao, estos es el mejor s\u014Dmen\r\nque has hecho nunca,
      aunque quiz\xE1\r\ntambi\xE9n es porque lo ech\xE9 mucho de\r\nmenos."
  - quienHabla: 0
    nombre: MAO MAO
    texto: 'Ten cuidado de no mancharte el

      uniforme.'
  - quienHabla: 0
    nombre: MAO MAO
    texto: 'Recuerdo como siempre

      estabas tan ansioso por comer lo que

      fuera
      que te preparase, que te

      olvidabas incluso de respirar.'
  - quienHabla: 1
    nombre: NATSU
    texto: "Me alegra que te acuerdes de lo mucho\r\nque lo disfrutaba. Aunque yo
      no era el\r\n\xFAnico que lo hac\xEDa...\r\n\r\n"
  - quienHabla: 1
    nombre: NATSU
    texto: "Espero que tengas buen d\xEDa, t\xEDa Mao\r\nMao. Nos vemos el mes que
      viene. A la\r\npr\xF3xima te traer\xE9 algo que haya hecho\r\nyo.\r\n"
